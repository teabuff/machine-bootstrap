#!/usr/bin/env bash
# dev-port — least-privilege firewall helper. Lets a developer open/close ONE
# non-privileged TCP test port via ufw, and nothing else: never the SSH port,
# never privileged ports (<1024), never the firewall itself (no disable/reset).
#
# Granted to a role's SCOPED sudo (Pangolin sshSudoCommands), so a developer runs:
#     sudo dev-port open  8080      # ufw allow 8080/tcp
#     sudo dev-port close 8080      # ufw delete allow 8080/tcp
#
# SECURITY: this must be installed root-owned and NOT writable by non-root
# (0755 root:root) — a dev-writable wrapper run via sudo is just a root shell.
# install_dev_port() in ssh-access.sh installs it that way.
set -euo pipefail

action=${1:-}
port=${2:-}

usage() {
  echo "usage: dev-port <open|close> <port>   (TCP 1024-65535, excluding the SSH port)" >&2
  exit 2
}

[[ $action == open || $action == close ]] || usage
[[ $port =~ ^[0-9]+$ ]] && ((port >= 1024 && port <= 65535)) || usage

# Refuse the live SSH port so a dev can't expose or disturb admin access.
sshd_port=$(sshd -T 2>/dev/null | awk '/^port /{print $2; exit}' || true)
if [[ -n ${sshd_port:-} && $port == "$sshd_port" ]]; then
  echo "dev-port: refusing the SSH port ($sshd_port)" >&2
  exit 2
fi

case $action in
  open) exec /usr/sbin/ufw allow "${port}/tcp" ;;
  close) exec /usr/sbin/ufw delete allow "${port}/tcp" ;;
esac

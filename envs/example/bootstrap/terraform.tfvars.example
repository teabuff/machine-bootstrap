# Copy to terraform.tfvars (gitignored). Non-secret per-env values only — the
# three secrets (cloudflare_api_token, pangolin_admin_password,
# pangolin_license_key) come from TF_VAR_* (see ../../.envrc.example).
server_ip            = "203.0.113.10"
base_domain          = "tyo.example.com" # gets *.tyo.example.com
dashboard_subdomain  = "pangolin"
cloudflare_zone_id   = "your-cloudflare-zone-id"
letsencrypt_email    = "you@example.com"
ssh_port             = 22
ssh_private_key_path = "~/.ssh/id_ed25519"
pangolin_admin_email = "admin@example.com" # lower-case

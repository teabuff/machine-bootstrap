# Provider + version pins. Works with OpenTofu (`tofu`) or Terraform (`terraform`)
# unchanged — the `terraform {}` block is shared between both.
terraform {
  required_version = ">= 1.6.0"

  required_providers {
    cloudflare = {
      source  = "cloudflare/cloudflare"
      version = "~> 5.0"
    }
    null = {
      source  = "hashicorp/null"
      version = "~> 3.2"
    }
    random = {
      source  = "hashicorp/random"
      version = "~> 3.6"
    }
    external = {
      source  = "hashicorp/external"
      version = "~> 2.3"
    }
  }
}

provider "cloudflare" {
  api_token = var.cloudflare_api_token
}

# Site (homelab) newt config — copy to .env. The provisioning key is single-use
# at the site's perspective: newt swaps it for a permanent id/secret on first
# boot, then wipes it. Generate the key once on the hub (blueprint or dashboard)
# and hand it to each site.
PANGOLIN_ENDPOINT=https://pangolin.example.com
NEWT_PROVISIONING_KEY=
NEWT_IMAGE=docker.io/fosrl/newt:1.5.0
